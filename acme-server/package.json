{
    "name": "secutor-acme",
    "version": "0.1.0",
    "description": "ACME (RFC 8555) server backed by secutor CA",
    "type": "module",
    "private": true,
    "bin": {
        "secutor-acme": "dist/server/index.js",
        "secutor-acme-client": "dist/client/index.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server/index.js",
        "dev": "tsx src/server/index.ts",
        "client": "tsx src/client/index.ts",
        "test": "node --import tsx --test test/*.test.ts",
        "e2e": "tsx test/e2e.ts && tsx test/intermediate.ts"
    },
    "dependencies": {
        "better-sqlite3": "^11.10.0",
        "fastify": "^4.28.1",
        "jose": "^5.9.6",
        "node-forge": "^1.3.1",
        "ulid": "^2.3.0",
        "yaml": "^2.5.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.11",
        "@types/node": "^20.11.0",
        "@types/node-forge": "^1.3.13",
        "tsx": "^4.19.2",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=18.17"
    }
}
