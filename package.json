{
    "name": "secutor",
    "version": "1.1.0",
    "description": "Interactive TUI certificate manager (CA, server, client, profiles)",
    "bin": {
        "secutor": "dist/cli.js"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "main": "dist/cli.js",
    "type": "module",
    "keywords": [
        "tui",
        "cli",
        "terminal",
        "interactive",
        "certificate",
        "ssl",
        "tls",
        "pki",
        "x509",
        "cert-manager",
        "management",
        "security",
        "openssl",
        "acme"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node dist/cli.js",
        "dev": "tsx src/cli.tsx",
        "test": "node --import tsx --test test/*.test.ts",
        "prepublishOnly": "npm run test && npm run build"
    },
    "dependencies": {
        "asn1js": "^3.0.10",
        "better-sqlite3": "^11.10.0",
        "ink": "^5.0.1",
        "ink-select-input": "^6.0.0",
        "ink-spinner": "^5.0.0",
        "ink-text-input": "^6.0.0",
        "node-forge": "^1.3.1",
        "pkijs": "^3.4.0",
        "pvutils": "^1.1.5",
        "react": "^18.3.1"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.11",
        "@types/node": "^20.11.0",
        "@types/node-forge": "^1.3.13",
        "@types/react": "^18.3.3",
        "tsx": "^4.19.2",
        "typescript": "^5.5.0"
    },
    "engines": {
        "node": ">=18.17"
    },
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "author": "kamighost",
    "license": "BSD-3-Clause"
}
